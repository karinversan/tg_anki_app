APP_ENV=development
STACK_NAME=tg_anki

POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=tg_anki
DATABASE_URL=postgresql+asyncpg://postgres:postgres@postgres:5432/tg_anki

REDIS_URL=redis://redis:6379/0
CELERY_BROKER_URL=redis://redis:6379/1
CELERY_RESULT_BACKEND=redis://redis:6379/2

API_BASE_URL=http://localhost:8000
WEB_BASE_URL=https://example.ngrok-free.app
VITE_API_BASE_URL=/api

BOT_TOKEN=replace-me
JWT_SECRET=replace-me
JWT_EXPIRES_MINUTES=15
ADMIN_TELEGRAM_IDS=

STORAGE_PATH=/app/data
ENCRYPTION_KEY_BASE64=replace-me
CLAMAV_HOST=clamav
CLAMAV_PORT=3310
CLAMAV_REQUIRED=false

LLM_PROVIDER=openrouter
OPENROUTER_API_KEY=
OPENROUTER_MODEL=qwen/qwen3-8b:free
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_REQUEST_TIMEOUT_SECONDS=180
OPENROUTER_TEMPERATURE=0.3
OPENROUTER_APP_NAME=Telegram Anki
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash-lite
RAG_USE_EMBEDDINGS=true
EMBEDDING_PROVIDER=gemini
HF_HUB_DISABLE_TELEMETRY=1
ANONYMIZED_TELEMETRY=false
FILTER_GENERIC_ANSWERS=true
GENERIC_ANSWER_PATTERNS=
GEMINI_EMBEDDING_MODEL=models/embedding-001
CHROMA_PATH=./data/chroma
RAG_TOP_K=5
RAG_MIN_TOPICS=3
RAG_MAX_TOPICS=12
RAG_MAX_CHUNKS=400
RAG_CLAIMS_PER_TOPIC=12
RAG_QUESTIONS_PER_TOPIC=6
RAG_JUDGE_BATCH_SIZE=8
RAG_REUSE_VECTOR_STORE=true
FILTER_UNRELATED_CONTENT=true
UNRELATED_CONTENT_PATTERNS=

JOB_WEBHOOK_URL=
CORS_ORIGINS=http://localhost:5173

RATE_LIMIT_GENERATIONS_PER_MINUTE=3
RATE_LIMIT_UPLOADS_PER_MINUTE=10
MAX_FILES_PER_TOPIC=10
MAX_FILE_SIZE_MB=20
JOB_EXTRACT_CONCURRENCY=4
JOB_CHUNK_CONCURRENCY=4
